# Super Quant Bot — environment template.
# Copy to `.env` and fill in values. All exchange credentials and
# trading parameters live in the database (configured through the UI),
# not here.

# ── Admin auth ──
# URL path prefix. 4+ chars recommended. Final URL:
#   http://<host>:3030/<ADMIN_PREFIX>/
ADMIN_PREFIX=mybot123
# Login password for the single admin user. Change immediately.
ADMIN_PASSWORD=changeme
# Google Authenticator TOTP secret (base32). Leave empty to disable 2FA.
ADMIN_2FA_SECRET=

# ── Database ──
# MySQL is the default. The docker-compose.yml runs a sibling
# `mysql` service; bot talks to it over the internal compose
# network. Direct access from host via `mysql -h 127.0.0.1 -P 3307
# -u $DB_USER -p $DB_NAME` (3307 avoids collision with any host
# MySQL on 3306).
DB_TYPE=mysql
DB_HOST=mysql
DB_PORT=3306
DB_USER=botuser
DB_PASSWORD=botpass
DB_NAME=superquant

# MySQL root password (used only by the `mysql` container on first
# boot to create the $DB_USER / $DB_NAME). Changing after init
# requires reset of the volume.
MYSQL_ROOT_PASSWORD=rootpw

# SQLite is kept as a legacy / dev-only option. Set DB_TYPE=sqlite
# to use it — the file is written at DB_PATH.
DB_PATH=./data/bot.db

# ── Redis cache (optional) ──
# Enable for lower latency on the realtime endpoints (spread / funding
# caches). When disabled, an in-process dict is used — works fine for
# a single-pod self-hosted deploy.
REDIS_ENABLED=1
REDIS_HOST=redis
REDIS_PORT=6379

# ── Engine ──
# 1 = simulated orders on real market data (paper trading).
# 0 = real orders. Can also be toggled at runtime via POST /control/debug-mode.
DEBUG_MODE=1

# Notification webhooks (feishu / telegram) have moved into the DB.
# Configure them in the UI under Settings → Notifications. On first
# boot, any FEISHU_WEBHOOK_URL / TELEGRAM_BOT_TOKEN / TELEGRAM_CHAT_ID
# env vars from older installs are copied into DB once, then can be
# removed.

# ── At-rest encryption for exchange API keys ──
# OPTIONAL. Leave empty — the bot auto-generates a Fernet master key
# on first start and persists it to `<DB_PATH dir>/.master.key`. The
# file lives in the same Docker volume as the DB, so a single
# volume-level backup captures both.
#
# Back up the ENTIRE data/ directory. Losing .master.key alone means
# every saved exchange API key becomes unreadable — you'd have to
# re-enter them through the Exchanges page.
#
# Set this variable explicitly only when the key should come from a
# secret manager (k8s Secret / Vault / AWS SSM) instead of disk.
# Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_ENCRYPTION_KEY=
